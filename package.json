{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:generated": "npm run generate:colours && npm run generate:issuers",
    "prepare:generated:full": "npm run generate:colours && npm run generate:interfaces && npm run generate:suggestions && npm run generate:issuers",
    "build": "npm run build:local",
    "build:local": "npm run prepare:generated && node scripts/run-with-env.mjs NUXT_BUILD_PROFILE=local -- nuxt build",
    "build:ci": "npm run prepare:generated:full && node scripts/run-with-env.mjs NUXT_BUILD_PROFILE=ci -- nuxt build",
    "dev": "npm run dev:local",
    "dev:local": "npm run prepare:generated && node scripts/run-with-env.mjs NUXT_BUILD_PROFILE=local -- nuxt dev --dotenv .env.local",
    "dev:full": "npm run prepare:generated:full && node scripts/run-with-env.mjs NUXT_BUILD_PROFILE=ci -- nuxt dev --dotenv .env.local",
    "dev:debug": "npm run prepare:generated && node scripts/run-with-env.mjs NUXT_BUILD_PROFILE=local -- nuxt dev --inspect --dotenv .env.local",
    "generate": "npm run build:ci",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "deploy": "npm run build:ci",
    "lint": "eslint --ext .ts,.vue .",
    "lint:fix": "eslint --ext .ts,.vue . --fix",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:data-quality": "node scripts/reset-data-quality-report.mjs && vitest run --project data-quality && node scripts/generate-stakeholder-quality-reports.mjs",
    "test:data-quality:watch": "vitest --project data-quality",
    "test:data-quality:report": "node scripts/reset-data-quality-report.mjs && vitest run --project data-quality --reporter=verbose && node scripts/generate-stakeholder-quality-reports.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke/home-search-detail.spec.ts tests/e2e/smoke/public-routes-auth.spec.ts tests/e2e/smoke/compare-press-assets-autocomplete.spec.ts tests/e2e/seo/search-canonical-robots.spec.ts",
    "test:e2e:list": "playwright test --list",
    "test:e2e:api": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts",
    "test:e2e:api:edge": "playwright test tests/e2e/api/backend-edge-cases.spec.ts",
    "test:e2e:api:openapi": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts --grep \"\\[openapi\\]\"",
    "test:e2e:api:detail": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts --grep \"\\[detail\\]\"",
    "test:e2e:api:search": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts --grep \"\\[search\\]\"",
    "test:e2e:api:search-matrix": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts --grep \"\\[search-matrix\\]\"",
    "test:e2e:api:negative": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts --grep \"\\[negative\\]\"",
    "test:e2e:api:health": "playwright test tests/e2e/api/backend-openapi-contract.spec.ts --grep \"\\[health\\]\"",
    "test:ci:fast": "yarn lint && yarn test:unit",
    "test:ci:lint": "yarn lint",
    "test:ci:api": "yarn test:e2e:api --workers=1 --reporter=list && yarn test:e2e:api:edge --workers=1 --reporter=list",
    "generate:colours": "tsx scripts/generate-scss-vars.ts",
    "generate:colors": "tsx scripts/generate-scss-vars.ts",
    "generate:interfaces": "node scripts/generate-interfaces.mjs",
    "generate:suggestions": "tsx scripts/generate-query-suggestions.ts",
    "generate:issuers": "tsx scripts/generate-issuer-data.ts",
    "generate:images": "node scripts/optimize-images.mjs",
    "generate:images:clean": "node scripts/optimize-images.mjs --clean",
    "check:images": "node scripts/optimize-images.mjs --check",
    "check:contrast": "tsx utils/contrastCheck.ts",
    "audit:accessibility": "echo 'Run your accessibility audit utility here'",
    "report:images": "node scripts/report-image-metadata.mjs",
    "test:normdata": "node --test scripts/tests/normdata-identifiers.test.mjs"
  },
  "dependencies": {
    "@dargmuesli/nuxt-cookie-control": "8.5.0",
    "@elastic/elasticsearch": "^8.17.0",
    "@formkit/addons": "^1.6.9",
    "@formkit/core": "^1.6.9",
    "@formkit/icons": "^1.6.9",
    "@formkit/inputs": "^1.6.9",
    "@formkit/nuxt": "^1.6.9",
    "@formkit/pro": "^0.122.21",
    "@formkit/themes": "^1.6.9",
    "@formkit/utils": "^1.6.9",
    "@nuxt/icon": "^1.10.2",
    "@nuxt/kit": "^4.1.3",
    "@nuxtjs/i18n": "^10.1.1",
    "@pinia-plugin-persistedstate/nuxt": "^1.2.1",
    "@searchkit/api": "^4.14.0",
    "@searchkit/instantsearch-client": "^4.14.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vueform/slider": "^2.1.10",
    "@vueuse/core": "^12.0.0",
    "@vueuse/nuxt": "^10.11.1",
    "algoliasearch": "^4",
    "axios": "^1.15.0",
    "cytoscape": "^3.29.2",
    "daisyui": "5.5.18",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "instantsearch.js": "^4.80.0",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.4",
    "nuxt": "^4.1.3",
    "nuxt-nodemailer": "^1.1.2",
    "nuxt3-winston-log": "^0.5.0",
    "pinia": "^2.3.0",
    "postcss": "^8.4.49",
    "searchkit": "^4.15.0",
    "tailwindcss": "^4.1.14",
    "uuid": "^13.0.0",
    "vite": "^7.3.2",
    "vite-plugin-commonjs": "^0.10.4",
    "vue": "^3.5.13",
    "vue-i18n": "^11",
    "vue-instantsearch": "^4.21.3",
    "vue-range-slider": "^0.6.0",
    "vue-router": "^4.5.0",
    "vue3-toastify": "^0.2.8",
    "yarn": "^1.22.22",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@iconify-json/formkit": "^1.2.2",
    "@iconify-json/tabler": "^1.2.23",
    "@nuxt/devtools": "^3.2.2",
    "@nuxtjs/seo": "^3.2.2",
    "@nuxtjs/sitemap": "^7.4.7",
    "@pinia/nuxt": "^0.5.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^7",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9",
    "eslint-plugin-vue": "^10.6.2",
    "export-to-csv": "^1.4.0",
    "happy-dom": "^20.9.0",
    "nuxt-schema-org": "^5.0.9",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass-embedded": "^1.93.2",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.2.0",
    "vue-matomo": "^4.2.0",
    "vue-router": "^4.5.0"
  },
  "resolutions": {
    "axios": "1.15.0",
    "brace-expansion": "5.0.5",
    "defu": "6.1.5",
    "fast-xml-parser": "5.5.7",
    "flatted": "3.4.2",
    "follow-redirects": "1.16.0",
    "h3": "1.15.9",
    "lodash": "4.18.0",
    "node-forge": "1.4.0",
    "nodemailer": "8.0.5",
    "nuxt-og-image": "6.2.5",
    "picomatch": "4.0.4",
    "serialize-javascript": "7.0.5",
    "simple-git": "3.32.3",
    "srvx": "0.11.13",
    "tar": "7.5.11",
    "undici": "6.24.0",
    "unhead": "2.1.13",
    "devalue": "5.6.4",
    "vite": "7.3.2",
    "immutable": "5.1.5",
    "yaml": "2.8.3",
    "svgo": "4.0.1"
  },
  "packageManager": "yarn@4.3.1"
}
