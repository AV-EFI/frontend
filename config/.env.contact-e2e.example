# Copy this file to .env.contact-e2e (or export these vars in your shell)
# before running the contact delivery e2e flow.

# SMTP used by /api/mail/contact
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_SECURE=false
# MAIL_USER=
# MAIL_PASSWORD=
MAIL_FROM=noreply@av-efi.local
MAIL_TO=qa@av-efi.local
MAIL_TO_2=

# Inbox API endpoint used by the e2e test to confirm delivery.
# For Mailpit this is usually http://127.0.0.1:8025
MAIL_ASSERT_API_BASE=http://127.0.0.1:8025
